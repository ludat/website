---
import { getCollection, render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import BlogPost from '../../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  const draftPosts = await getCollection('drafts');
  const allPosts = [...blogPosts, ...draftPosts];

  const paths = allPosts.map(page => {
    const slashIndex = page.id.lastIndexOf('/');
    const dirName = page.id.substring(0, slashIndex);
    const locale = page.id.substring(slashIndex + 1);

    // Find sibling posts (same directory, different locale) for alternate URLs
    const alternateUrls: Record<string, string> = {};
    for (const sibling of allPosts) {
      const sibSlashIndex = sibling.id.lastIndexOf('/');
      const sibDir = sibling.id.substring(0, sibSlashIndex);
      const sibLocale = sibling.id.substring(sibSlashIndex + 1);
      if (sibDir === dirName) {
        alternateUrls[sibLocale] = getRelativeLocaleUrl(sibLocale, `/blog/${sibling.data.urlSlug}/`);
      }
    }

    return {
      params: { locale, slug: page.data.urlSlug },
      props: { post: page, alternateUrls },
    };
  });

  return paths;
}

const { post, alternateUrls } = Astro.props;
Astro.locals.alternateUrls = alternateUrls;
const { Content } = await render(post);
---

<BlogPost {...post.data} alternateUrls={alternateUrls}>
  <Content />
</BlogPost>
