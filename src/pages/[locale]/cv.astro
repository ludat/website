---
import { getEntry, render } from 'astro:content';
import { languages } from '../../i18n/ui';
import type { Lang } from '../../i18n/utils';
import Page from '../../layouts/Page.astro';

export function getStaticPaths() {
	return Object.keys(languages).map((locale) => ({ params: { locale } }));
}

const locale = Astro.currentLocale as Lang;
const page = await getEntry('pages', `cv/${locale}`)!;
const { Content } = await render(page);
---

<Page title={`${page.data.title} - Ludat`} description={page.data.description}>
	<Content />
</Page>

<style>
	section {
		margin-bottom: 2.5em;
	}

	section h2 {
		border-bottom: 2px solid rgb(var(--gray-light));
		padding-bottom: 0.3em;
		margin-bottom: 1em;
	}

	.entry {
		margin-bottom: 2em;
	}

	.entry-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 0.5em;
		margin-bottom: 0.5em;
	}

	.entry-header h3 {
		margin: 0;
		font-size: 1.3em;
	}

	.role {
		color: rgb(var(--gray));
		font-size: 0.95em;
	}

	.meta {
		text-align: right;
		font-size: 0.9em;
		color: rgb(var(--gray));
	}

	.meta .location {
		display: block;
	}

	.entry p {
		margin: 0.3em 0 0.5em;
	}

	.projects-list {
		margin: 0.5em 0;
		padding-left: 1.2em;
	}

	.projects-list li {
		margin-bottom: 0.3em;
		font-size: 0.95em;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
		margin-top: 0.5em;
	}

	.tags span {
		background: rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
		padding: 0.15em 0.6em;
		border-radius: 4px;
		font-size: 0.8em;
	}

	.languages {
		list-style: none;
		padding: 0;
	}

	.languages li {
		margin-bottom: 0.3em;
	}

	@media (max-width: 720px) {
		.entry-header {
			flex-direction: column;
		}

		.meta {
			text-align: left;
		}
	}
</style>
