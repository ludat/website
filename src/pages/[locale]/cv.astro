---
import { getEntry, render } from 'astro:content';
import { languages } from '../../i18n/ui';
import type { Lang } from '../../i18n/utils';
import CvLayout from '../../layouts/CvLayout.astro';

export function getStaticPaths() {
  return Object.keys(languages).map((locale) => ({ params: { locale } }));
}

const locale = Astro.currentLocale as Lang;
const page = await getEntry('pages', `cv/${locale}`)!;
const { Content } = await render(page);
---

<CvLayout title={`${page.data.title} - Ludat`} description={page.data.description}>
  <Content />
</CvLayout>
