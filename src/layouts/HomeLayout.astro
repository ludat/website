---
import BaseHead from '../components/BaseHead.astro';
import Navbar from '../components/Navbar.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
const lang = Astro.currentLocale as Lang;
const t = useTranslations(lang);
---

<html lang={lang} data-theme="dark">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<div class="home-page">
			<div class="home-grid-bg"></div>

			<Navbar activePath="/" />

			<main class="home-hero">
				<div class="home-hero-inner">
					<div class="site-eyebrow">{t('home.eyebrow')}</div>

					<h1 class="home-headline">
						{t('home.headline.pre').split('\n').map((line, i) => (
							<Fragment>
								{i > 0 && <br />}
								{line}
							</Fragment>
						))}<em>{t('home.headline.accent')}</em>
					</h1>

					<p class="home-tagline">
						<strong>{t('home.tagline.fullstack')}</strong>
						{' '}{t('home.tagline').split('{fullstack}')[1]?.split('{devops}')[0]}
						<strong>{t('home.tagline.devops')}</strong>
						{t('home.tagline').split('{devops}')[1]?.split('{haskell}')[0]}
						<strong>{t('home.tagline.haskell')}</strong>
						{t('home.tagline').split('{haskell}')[1]}
						<br /><br />
						{t('home.tagline2')}
					</p>

					<div class="home-ctas">
						<a class="home-btn-primary" href={getRelativeLocaleUrl(lang, '/blog')}>
							<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
							{t('home.cta.blog')}
						</a>
						<a class="home-btn-ghost" href={getRelativeLocaleUrl(lang, '/cv')}>
							<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
							{t('home.cta.cv')}
						</a>
					</div>

					<div class="home-social-row">
						<span class="home-social-label">{t('home.social.label')}</span>
						<div class="home-social-links">
							<a class="home-social-link" href="https://github.com/ludat" target="_blank" rel="noopener noreferrer">
								<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
								GitHub
							</a>
							<a class="home-social-link" href="https://linkedin.com/in/ludat" target="_blank" rel="noopener noreferrer">
								<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
								LinkedIn
							</a>
							<a class="home-social-link" href="https://gitlab.com/ludat" target="_blank" rel="noopener noreferrer">
								<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23 13.45a.84.84 0 0 1-.35.94z"/></svg>
								GitLab
							</a>
						</div>
					</div>
				</div>
			</main>

			<SiteFooter />
		</div>
	</body>
</html>

<style>
	html, body {
		height: 100%;
	}

	/* ── Page ── */
	.home-page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.home-page > * {
		position: relative;
		z-index: 1;
	}

	/* ── Decorative grid ── */
	.home-grid-bg {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		background-image:
			linear-gradient(var(--site-border) 1px, transparent 1px),
			linear-gradient(90deg, var(--site-border) 1px, transparent 1px);
		background-size: 64px 64px;
		mask-image: radial-gradient(ellipse 60% 70% at 20% 50%, black 0%, transparent 100%);
		opacity: 0.35;
	}

	/* ── Hero ── */
	.home-hero {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 52px 40px 0;
	}

	.home-hero-inner {
		max-width: 640px;
		width: 100%;
	}

	.home-headline {
		font-size: clamp(48px, 7vw, 80px);
		font-weight: 700;
		letter-spacing: -0.04em;
		line-height: 0.95;
		color: var(--site-text);
		margin-bottom: 28px;
	}

	.home-headline em {
		font-style: normal;
		color: var(--site-accent);
	}

	.home-tagline {
		font-size: 16px;
		color: var(--site-text-muted);
		line-height: 1.7;
		text-wrap: pretty;
		max-width: 480px;
		margin-bottom: 44px;
	}

	.home-tagline strong {
		color: var(--site-text);
		font-weight: 500;
	}

	/* ── CTAs ── */
	.home-ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		align-items: center;
	}

	.home-btn-primary {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 12px;
		color: var(--site-bg);
		background: var(--site-accent);
		padding: 10px 20px;
		border-radius: 3px;
		text-decoration: none;
		letter-spacing: 0.04em;
		transition: opacity 0.2s;
	}

	.home-btn-primary:hover {
		opacity: 0.85;
	}

	.home-btn-ghost {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 12px;
		color: var(--site-text-muted);
		padding: 10px 20px;
		border-radius: 3px;
		border: 1px solid var(--site-border);
		text-decoration: none;
		letter-spacing: 0.04em;
		transition: color 0.2s, border-color 0.2s;
	}

	.home-btn-ghost:hover {
		color: var(--site-text);
		border-color: var(--site-text-muted);
	}

	/* ── Social row ── */
	.home-social-row {
		display: flex;
		align-items: center;
		gap: 20px;
		margin-top: 52px;
		padding-top: 28px;
		border-top: 1px solid var(--site-border);
	}

	.home-social-label {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 10px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--site-text-faint);
		white-space: nowrap;
	}

	.home-social-links {
		display: flex;
		gap: 4px;
	}

	.home-social-link {
		display: flex;
		align-items: center;
		gap: 7px;
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 11px;
		color: var(--site-text-faint);
		text-decoration: none;
		padding: 5px 10px;
		border-radius: 3px;
		transition: color 0.2s, background 0.2s;
	}

	.home-social-link:hover {
		color: var(--site-accent);
		background: var(--site-bg-surface);
	}

	.home-social-link :global(svg) {
		flex-shrink: 0;
	}

	/* ── Responsive ── */
	@media (max-width: 600px) {
		.home-hero {
			padding: 80px 24px 40px;
		}

		.home-headline {
			font-size: 44px;
		}

		.home-social-row {
			flex-wrap: wrap;
		}
	}
</style>
