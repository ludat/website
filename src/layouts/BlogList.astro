---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Navbar from '../components/Navbar.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, type Lang } from '../i18n/utils';

const lang = Astro.currentLocale as Lang;
const t = useTranslations(lang);
const localeMap = { en: 'en-us', es: 'es-ar' } as const;

const posts = (await getCollection('blog'))
	.filter((post) => post.id.endsWith(`/${lang}`))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts[0];
const olderPosts = posts.slice(1);
const olderCount = olderPosts.length;

const latestDate = featured?.data.pubDate;
const latestMonth = latestDate
	? latestDate.toLocaleDateString(localeMap[lang], { month: 'short', year: 'numeric' })
	: '';

function formatOlderPosts(count: number): string {
	const template = t('blog.olderPosts', { count: String(count) });
	const [singular, plural] = template.split('||');
	return count === 1 ? singular : (plural ?? singular);
}
---

<!doctype html>
<html lang={lang} data-theme="dark">
	<head>
		<BaseHead title={`Blog — ${t('site.title')}`} description={t('blog.sidebar.description')} />
	</head>
	<body>
		<Navbar activePath="/blog" />

		<div class="blog-layout">
			<aside class="blog-sidebar">
				<div>
					<div class="blog-sidebar-title">
						Blog
						<span>ludat.io/{lang}/blog</span>
					</div>
				</div>

				<p class="blog-sidebar-desc">{t('blog.sidebar.description')}</p>

				<div>
					<div class="blog-sidebar-label">{t('blog.sidebar.stats')}</div>
					<div class="blog-sidebar-stats">
						<div class="blog-stat-item">
							<span>{t('blog.sidebar.posts')}</span>
							<span class="blog-stat-value">{posts.length}</span>
						</div>
						<div class="blog-stat-item">
							<span>{t('blog.sidebar.latest')}</span>
							<span class="blog-stat-value">{latestMonth}</span>
						</div>
					</div>
				</div>
			</aside>

			<main class="blog-page">
				{featured && (
					<div class="blog-featured">
						<div class="blog-featured-label">{t('blog.featured.label')}</div>
						<a class="blog-featured-card" href={getRelativeLocaleUrl(lang, `/blog/${featured.data.urlSlug}/`)}>
							<div class="blog-featured-meta">
								<time datetime={featured.data.pubDate.toISOString()}>
									{featured.data.pubDate.toLocaleDateString(localeMap[lang], { year: 'numeric', month: 'short', day: 'numeric' })}
								</time>
							</div>
							<div class="blog-featured-title">{featured.data.title}</div>
							<div class="blog-featured-summary">{featured.data.description}</div>
							<div class="blog-featured-arrow">
								{t('blog.featured.read')}
								<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
							</div>
						</a>
					</div>
				)}

				{olderCount > 0 && (
					<>
						<div class="blog-post-count">{formatOlderPosts(olderCount)}</div>
						<div class="blog-post-list">
							{olderPosts.map((post) => {
								const d = post.data.pubDate;
								return (
									<a class="blog-post-item" href={getRelativeLocaleUrl(lang, `/blog/${post.data.urlSlug}/`)}>
										<div class="blog-post-date">
											<span class="blog-post-date-day">{d.getUTCDate()}</span>
											<span class="blog-post-date-month">{d.toLocaleDateString(localeMap[lang], { month: 'short' })}</span>
											<span class="blog-post-date-year">{d.getUTCFullYear()}</span>
										</div>
										<div class="blog-post-body">
											<div class="blog-post-title">{post.data.title}</div>
											<div class="blog-post-summary">{post.data.description}</div>
											<div class="blog-post-footer">
												<div class="blog-post-arrow">
													{t('blog.featured.read')}
													<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
												</div>
											</div>
										</div>
									</a>
								);
							})}
						</div>
					</>
				)}
			</main>
		</div>

		<SiteFooter />
	</body>
</html>

<style>
	/* ── Layout ── */
	.blog-layout {
		display: grid;
		grid-template-columns: 280px 1fr;
		min-height: calc(100vh - 52px);
		max-width: 1200px;
		margin: 0 auto;
		padding-top: 52px;
	}

	/* ── Sidebar ── */
	.blog-sidebar {
		position: sticky;
		top: 52px;
		height: calc(100vh - 52px);
		overflow-y: auto;
		border-right: 1px solid var(--site-border);
		padding: 48px 32px;
		display: flex;
		flex-direction: column;
		gap: 36px;
		scrollbar-width: none;
	}

	.blog-sidebar::-webkit-scrollbar {
		display: none;
	}

	.blog-sidebar-title {
		font-size: 22px;
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.1;
		color: var(--site-text);
	}

	.blog-sidebar-title span {
		display: block;
		font-size: 13px;
		font-weight: 400;
		font-family: 'Space Mono', ui-monospace, monospace;
		color: var(--site-accent);
		letter-spacing: 0.04em;
		margin-top: 6px;
	}

	.blog-sidebar-desc {
		font-size: 13px;
		color: var(--site-text-muted);
		line-height: 1.7;
		text-wrap: pretty;
	}

	.blog-sidebar-label {
		font-size: 10px;
		font-family: 'Space Mono', ui-monospace, monospace;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--site-text-faint);
		margin-bottom: 8px;
	}

	.blog-sidebar-stats {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.blog-stat-item {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		font-size: 12px;
		padding: 6px 0;
		border-bottom: 1px solid var(--site-border);
		color: var(--site-text-muted);
	}

	.blog-stat-item:last-child {
		border-bottom: none;
	}

	.blog-stat-value {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 11px;
		color: var(--site-accent);
	}

	/* ── Main page ── */
	.blog-page {
		padding: 56px 64px 120px;
		min-width: 0;
	}

	/* ── Featured post ── */
	.blog-featured {
		margin-bottom: 64px;
	}

	.blog-featured-label {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 10px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--site-accent);
		margin-bottom: 16px;
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.blog-featured-label::after {
		content: '';
		flex: 1;
		height: 1px;
		background: var(--site-border);
	}

	.blog-featured-card {
		display: block;
		text-decoration: none;
		color: inherit;
		border: 1px solid var(--site-border);
		border-radius: 6px;
		padding: 36px 40px;
		background: var(--site-bg-surface);
		transition: border-color 0.2s, background 0.2s;
		position: relative;
		overflow: hidden;
	}

	.blog-featured-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: var(--site-accent);
		opacity: 0.7;
	}

	.blog-featured-card:hover {
		border-color: var(--site-accent-dim);
		background: var(--site-bg-hover);
	}

	.blog-featured-card:hover .blog-featured-title {
		color: var(--site-accent);
	}

	.blog-featured-card:hover .blog-featured-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	.blog-featured-meta {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 11px;
		color: var(--site-text-faint);
		margin-bottom: 14px;
	}

	.blog-featured-title {
		font-size: 22px;
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.3;
		color: var(--site-text);
		margin-bottom: 12px;
		text-wrap: pretty;
		transition: color 0.2s;
	}

	.blog-featured-summary {
		font-size: 14px;
		color: var(--site-text-muted);
		line-height: 1.7;
		text-wrap: pretty;
		max-width: 560px;
	}

	.blog-featured-arrow {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 11px;
		color: var(--site-accent);
		margin-top: 20px;
		opacity: 0;
		transform: translateX(-4px);
		transition: opacity 0.2s, transform 0.2s;
	}

	/* ── Post count ── */
	.blog-post-count {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 11px;
		color: var(--site-text-faint);
		margin-bottom: 32px;
		letter-spacing: 0.04em;
	}

	/* ── Post list ── */
	.blog-post-list {
		display: flex;
		flex-direction: column;
	}

	.blog-post-item {
		display: grid;
		grid-template-columns: 96px 1fr;
		gap: 0 32px;
		padding: 32px 16px;
		border-bottom: 1px solid var(--site-border);
		text-decoration: none;
		color: inherit;
		transition: background 0.15s;
		border-radius: 4px;
		margin: 0 -16px;
	}

	.blog-post-item:first-child {
		border-top: 1px solid var(--site-border);
	}

	.blog-post-item:hover {
		background: var(--site-bg-surface);
	}

	.blog-post-item:hover .blog-post-title {
		color: var(--site-accent);
	}

	.blog-post-item:hover .blog-post-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	.blog-post-date {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 11px;
		color: var(--site-text-faint);
		padding-top: 5px;
		line-height: 1.4;
	}

	.blog-post-date-day {
		display: block;
		font-size: 22px;
		font-weight: 700;
		font-family: 'Space Grotesk', system-ui, sans-serif;
		color: var(--site-text-faint);
		letter-spacing: -0.02em;
		line-height: 1;
		margin-bottom: 3px;
	}

	.blog-post-date-month {
		display: block;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 10px;
	}

	.blog-post-date-year {
		display: block;
		font-size: 10px;
		opacity: 0.7;
		margin-top: 1px;
	}

	.blog-post-body {
		display: flex;
		flex-direction: column;
		gap: 8px;
		min-width: 0;
	}

	.blog-post-title {
		font-size: 18px;
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--site-text);
		line-height: 1.3;
		transition: color 0.2s;
		text-wrap: pretty;
	}

	.blog-post-summary {
		font-size: 13.5px;
		color: var(--site-text-muted);
		line-height: 1.65;
		text-wrap: pretty;
	}

	.blog-post-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: 4px;
	}

	.blog-post-arrow {
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 11px;
		color: var(--site-accent);
		opacity: 0;
		transform: translateX(-4px);
		transition: opacity 0.2s, transform 0.2s;
		display: flex;
		align-items: center;
		gap: 6px;
	}

	/* ── Responsive ── */
	@media (max-width: 800px) {
		.blog-layout {
			grid-template-columns: 1fr;
		}

		.blog-sidebar {
			position: static;
			height: auto;
			border-right: none;
			border-bottom: 1px solid var(--site-border);
			padding: 32px 24px;
		}

		.blog-page {
			padding: 40px 24px 80px;
		}

		.blog-post-item {
			grid-template-columns: 1fr;
			gap: 8px;
			margin: 0 -12px;
			padding-left: 12px;
			padding-right: 12px;
		}

		.blog-post-date {
			display: flex;
			gap: 6px;
			align-items: baseline;
		}

		.blog-post-date-day {
			font-size: 14px;
		}

		.blog-footer {
			padding: 28px 24px;
		}
	}
</style>
