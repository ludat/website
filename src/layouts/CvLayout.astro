---
import BaseHead from '../components/BaseHead.astro';
import Navbar from '../components/Navbar.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
const lang = Astro.currentLocale as Lang;
const t = useTranslations(lang);

const sectionNav = lang === 'es'
	? [
		{ id: 'experiencia-profesional', label: 'Experiencia' },
		{ id: 'proyectos', label: 'Proyectos' },
		{ id: 'charlas', label: 'Charlas' },
		{ id: 'formación', label: 'Formación' },
	]
	: [
		{ id: 'professional-experience', label: 'Experience' },
		{ id: 'projects', label: 'Projects' },
		{ id: 'talks', label: 'Talks' },
		{ id: 'education', label: 'Education' },
	];

const spokenLanguages = lang === 'es'
	? [
		{ name: 'Español', level: 'nativo' },
		{ name: 'Inglés', level: 'avanzado' },
	]
	: [
		{ name: 'Spanish', level: 'native' },
		{ name: 'English', level: 'advanced' },
	];

const langLabel = lang === 'es' ? 'Idiomas' : 'Languages';
const navLabel = lang === 'es' ? 'En esta página' : 'On this page';
---

<html lang={lang} data-theme="dark">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Navbar activePath="/cv" />

		<div class="cv-layout">
			<aside class="cv-sidebar">
				<div>
					<div class="cv-name">
						Lucas David<br />Traverso
						<span>Software Engineer</span>
					</div>
				</div>

				<div class="cv-social-links">
					<a href="https://ludat.io" target="_blank" rel="noopener noreferrer">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
						ludat.io
					</a>
					<a href="https://github.com/ludat" target="_blank" rel="noopener noreferrer">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
						github.com/ludat
					</a>
					<a href="https://linkedin.com/in/ludat" target="_blank" rel="noopener noreferrer">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
						linkedin.com/in/ludat
					</a>
					<a href="https://gitlab.com/ludat" target="_blank" rel="noopener noreferrer">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23 13.45a.84.84 0 0 1-.35.94z"/></svg>
						gitlab.com/ludat
					</a>
				</div>

				<nav class="cv-section-nav">
					<div class="cv-nav-label">{navLabel}</div>
					{sectionNav.map(s => (
						<a class="cv-section-link" href={`#${s.id}`}>{s.label}</a>
					))}
				</nav>

				<div class="cv-spoken-langs">
					<div class="cv-nav-label">{langLabel}</div>
					{spokenLanguages.map(l => (
						<div class="cv-lang-item">
							<span>{l.name}</span>
							<span class="cv-lang-level">{l.level}</span>
						</div>
					))}
				</div>
			</aside>

			<main class="cv-main">
				<div class="cv-content">
					<slot />
				</div>

				<SiteFooter />
			</main>
		</div>
	</body>
</html>

<style>
	/* ── Layout ── */
	.cv-layout {
		display: grid;
		grid-template-columns: 280px 1fr;
		min-height: calc(100vh - 52px);
		max-width: 1200px;
		margin: 0 auto;
		padding-top: 52px;
	}

	/* ── Sidebar ── */
	.cv-sidebar {
		position: sticky;
		top: 52px;
		height: calc(100vh - 52px);
		overflow-y: auto;
		border-right: 1px solid var(--site-border);
		padding: 48px 32px;
		display: flex;
		flex-direction: column;
		gap: 40px;
		scrollbar-width: none;
	}

	.cv-sidebar::-webkit-scrollbar {
		display: none;
	}

	.cv-name {
		font-size: 22px;
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.1;
		color: var(--site-text);
	}

	.cv-name span {
		display: block;
		font-size: 13px;
		font-weight: 400;
		font-family: 'Space Mono', ui-monospace, monospace;
		color: var(--site-accent);
		letter-spacing: 0.04em;
		margin-top: 6px;
	}

	.cv-social-links {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.cv-social-links a {
		display: flex;
		align-items: center;
		gap: 10px;
		color: var(--site-text-muted);
		text-decoration: none;
		font-size: 13px;
		font-family: 'Space Mono', ui-monospace, monospace;
		padding: 6px 0;
		transition: color 0.2s;
	}

	.cv-social-links a:hover {
		color: var(--site-accent);
	}

	.cv-social-links a :global(svg) {
		flex-shrink: 0;
		opacity: 0.6;
	}

	.cv-social-links a:hover :global(svg) {
		opacity: 1;
	}

	.cv-section-nav {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.cv-nav-label {
		font-size: 10px;
		font-family: 'Space Mono', ui-monospace, monospace;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--site-text-faint);
		margin-bottom: 8px;
	}

	.cv-section-link {
		text-decoration: none;
		color: var(--site-text-muted);
		font-size: 13px;
		padding: 5px 0 5px 12px;
		border-left: 2px solid transparent;
		transition: color 0.2s, border-color 0.2s;
		display: block;
	}

	.cv-section-link:hover {
		color: var(--site-text);
		border-left-color: var(--site-accent);
	}

	.cv-spoken-langs {
		margin-top: auto;
	}

	.cv-lang-item {
		display: flex;
		justify-content: space-between;
		font-size: 12px;
		padding: 4px 0;
		color: var(--site-text-muted);
		border-bottom: 1px solid var(--site-border);
	}

	.cv-lang-item:last-child {
		border-bottom: none;
	}

	.cv-lang-level {
		font-family: 'Space Mono', ui-monospace, monospace;
		color: var(--site-accent);
		font-size: 11px;
	}

	/* ── Main ── */
	.cv-main {
		padding: 64px 64px 120px 64px;
		min-width: 0;
	}

	/* ── MDX Content Styles ── */
	.cv-content {
		margin-bottom: 80px;
	}

	/* Section headers (h2) */
	.cv-content :global(h2) {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-bottom: 40px;
		margin-top: 80px;
		font-size: 11px;
		font-family: 'Space Mono', ui-monospace, monospace;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--site-accent);
		font-weight: 400;
	}

	.cv-content :global(h2:first-child) {
		margin-top: 0;
	}

	.cv-content :global(h2)::after {
		content: '';
		flex: 1;
		height: 1px;
		background: var(--site-border);
	}

	/* Entry org names (h3) */
	.cv-content :global(h3) {
		font-size: 18px;
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--site-text);
		padding-top: 28px;
		margin-bottom: 0;
	}

	.cv-content :global(h2 + h3) {
		padding-top: 0;
	}

	.cv-content :global(h3 a) {
		color: inherit;
		text-decoration: none;
		border-bottom: 1px solid var(--site-accent-dim);
		transition: border-color 0.2s;
	}

	.cv-content :global(h3 a:hover) {
		border-color: var(--site-accent);
	}

	/* Description paragraphs */
	.cv-content :global(p) {
		font-size: 14px;
		color: var(--site-text-muted);
		line-height: 1.7;
		text-wrap: pretty;
		margin-bottom: 14px;
	}

	/* Bullet lists */
	.cv-content :global(ul) {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 6px;
		margin-bottom: 16px;
		padding-left: 0;
	}

	.cv-content :global(li) {
		font-size: 13.5px;
		color: var(--site-text-muted);
		padding-left: 16px;
		position: relative;
		line-height: 1.6;
		text-wrap: pretty;
	}

	.cv-content :global(li)::before {
		content: '\2014';
		position: absolute;
		left: 0;
		color: var(--site-accent);
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 11px;
		top: 2px;
	}

	.cv-content :global(li strong) {
		color: var(--site-text);
		font-weight: 600;
	}

	.cv-content :global(li a) {
		color: var(--site-text);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: color 0.2s, border-color 0.2s;
	}

	.cv-content :global(li a:hover) {
		color: var(--site-accent);
		border-bottom-color: var(--site-accent-dim);
	}

	/* Entry dividers — between entries within a section, not on the first */
	.cv-content :global(h3 ~ h3) {
		border-top: 1px solid var(--site-border);
	}

	.cv-content :global(h2 + h3) {
		border-top: none;
	}

	/* Hide Languages section (it's in the sidebar now) */
	.cv-content :global(#languages),
	.cv-content :global(#languages + ul),
	.cv-content :global(#idiomas),
	.cv-content :global(#idiomas + ul) {
		display: none;
	}

	/* ── Responsive ── */
	@media (max-width: 800px) {
		.cv-layout {
			grid-template-columns: 1fr;
		}

		.cv-sidebar {
			position: static;
			height: auto;
			border-right: none;
			border-bottom: 1px solid var(--site-border);
			padding: 32px 24px;
		}

		.cv-main {
			padding: 40px 24px 80px;
		}
	}

	@media print {
		.cv-sidebar {
			position: static;
			height: auto;
		}

		body {
			font-size: 11px;
		}
	}
</style>
