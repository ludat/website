---
import type { Lang } from '../i18n/utils';

interface Props {
  date: Date;
}

const { date } = Astro.props;
const lang = Astro.currentLocale as Lang;
const localeMap = { en: 'en-us', es: 'es-ar' } as const;
---

<time datetime={date.toISOString()}>
  {
    date.toLocaleDateString(localeMap[lang], {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  }
</time>
